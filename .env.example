# LSC environment variables — copy to .env.local for local dev
# In production, set these in Vercel project settings → Environment Variables.

# ── Forms ──
# Optional: forwards all form submissions (contact, /submissions, newsletter,
# lead magnet) to a Make.com webhook so the existing MailerLite "Brew-tiful
# Guide" automation keeps firing. Without this, submissions are logged
# server-side but NOT forwarded anywhere.
#
# Get the URL from your Make.com scenario → first module (Webhooks) → "Copy
# address to clipboard".
MAKE_WEBHOOK_URL=

# ── Phase 4 (not used in v1) ──
# Supabase, Resend etc. will be added here once we swap JSON → Supabase.
